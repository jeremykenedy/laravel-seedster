{
    "name": "jeremykenedy/laravel-seedster",
    "description": "Register and run Laravel database seeds from packages. Fork of eklundkristoffer/seedster with Laravel 13+ support.",
    "license": "MIT",
    "keywords": ["laravel", "seed", "seeder", "package"],
    "authors": [
        {
            "name": "Jeremy Kenedy",
            "email": "jeremykenedy@gmail.com"
        },
        {
            "name": "Kristoffer Eklund",
            "email": "kristoffereklund1@gmail.com",
            "role": "Original Author"
        }
    ],
    "require": {
        "php": "^8.2",
        "illuminate/support": "^9.0|^10.0|^11.0|^12.0|^13.0",
        "illuminate/console": "^9.0|^10.0|^11.0|^12.0|^13.0",
        "illuminate/database": "^9.0|^10.0|^11.0|^12.0|^13.0"
    },
    "autoload": {
        "psr-4": {
            "Jeremykenedy\\LaravelSeedster\\": "src/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Jeremykenedy\\LaravelSeedster\\Providers\\SeedsterServiceProvider"
            ]
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
